# Environment Configuration
# Copy this file to .env and update values

# Secret key for session signing (generate a random 32+ character string)
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Database URL (SQLite)
DATABASE_URL=sqlite:///./data/tool_repository.db

# Upload directory for .exe files
UPLOAD_DIR=./uploads

# Maximum file size in bytes (150MB = 157286400)
MAX_FILE_SIZE=157286400

# Default admin credentials (only used for initial setup)
ADMIN_USERNAME=nagarkotadmin
ADMIN_PASSWORD=nagarkotadmin
ADMIN_EMAIL=admin@nagarkot.co.in
